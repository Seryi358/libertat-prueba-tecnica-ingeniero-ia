APP_ENV=local
APP_BASE_URL=http://127.0.0.1:8000
DATABASE_PATH=data/libertat_webinar.sqlite3

# Modelo de lenguaje local opcional.
# Si no se configura, la aplicación usa un generador determinístico para la demo.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
OLLAMA_ENABLED=false

# Canal de notificación. Si SMTP_ENABLED=false, se guarda un .eml en data/outbox.
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=educacion@libertat.local
