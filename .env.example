APP_ENV=local
APP_BASE_URL=http://127.0.0.1:8000
DATABASE_PATH=data/libertat_webinar.sqlite3

# Modelo de lenguaje local opcional.
# Si no se configura, la aplicación usa un generador determinístico para la demo.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
OLLAMA_ENABLED=false

# API de modelo opcional para generacion activa en produccion.
MODEL_API_ENABLED=false
MODEL_API_URL=
MODEL_API_KEY=
MODEL_API_MODEL=

# Sincronizacion opcional a Supabase.
SUPABASE_SYNC_ENABLED=false
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Canales de notificacion. Valores: email, slack, whatsapp.
# Si faltan credenciales, se guarda evidencia local en data/outbox.
NOTIFICATION_CHANNELS=email

# Email SMTP.
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=educacion@libertat.local

# Gmail API opcional. Requiere refresh token OAuth con alcance gmail.send.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM=

# Slack Incoming Webhook opcional.
SLACK_WEBHOOK_URL=

# WhatsApp opcional. Se puede usar Evolution API, webhook propio/Kapso o WhatsApp Cloud API.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
WHATSAPP_WEBHOOK_URL=
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_DEFAULT_TO=
